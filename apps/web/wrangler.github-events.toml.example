# GitHub Events Worker 配置
# 复制此文件为 wrangler.github-events.toml 并填入你的配置
# 轮询 GitHub Events API，发现新的 SKILL.md 文件
# GitHub API 鉴权请通过 wrangler secret 设置 `GITHUB_TOKEN` 或 `GITHUB_TOKENS`

name = "skillscat-github-events"
main = "workers/github-events.ts"
compatibility_date = "2025-01-01"
compatibility_flags = ["nodejs_compat"]

workers_dev = false
preview_urls = false

[observability]
enabled = true
head_sampling_rate = 1

# Cron Trigger - 每 5 分钟轮询一次

[triggers]
crons = ["*/5 * * * *"]

# D1 Database
[[d1_databases]]
binding = "DB"
database_name = "skillscat-db"
database_id = "<your-database-id>"

# KV - 用于存储轮询状态
[[kv_namespaces]]
binding = "KV"
id = "<your-kv-namespace-id>"

# R2 Storage
[[r2_buckets]]
binding = "R2"
bucket_name = "skillscat-storage"

# Queue - 发送到 indexing 队列
[[queues.producers]]
binding = "INDEXING_QUEUE"
queue = "skillscat-indexing"

[vars]
GITHUB_EVENTS_PER_PAGE = "100"
GITHUB_EVENTS_PAGES = "1"
GITHUB_EVENTS_MIN_REST_REMAINING = "1000"
GITHUB_EVENTS_REST_RESERVE = "300"
GITHUB_SEARCH_DISCOVERY_ENABLED = "1"
GITHUB_SEARCH_DISCOVERY_QUERY = "filename:SKILL.md"
GITHUB_SEARCH_DISCOVERY_PAGES = "1"
GITHUB_SEARCH_DISCOVERY_PER_PAGE = "100"
GITHUB_DISCOVERY_CRON_INTERVAL_SECONDS = "300"
GITHUB_DISCOVERY_MIN_REST_REMAINING = "1000"
GITHUB_DISCOVERY_REST_RESERVE = "300"
GITHUB_DISCOVERY_LOCK_TTL_SECONDS = "240"

[env.production]
name = "skillscat-github-events-production"

[env.production.triggers]
crons = ["*/5 * * * *"]

[[env.production.d1_databases]]
binding = "DB"
database_name = "skillscat-db"
database_id = "<your-production-database-id>"

[[env.production.kv_namespaces]]
binding = "KV"
id = "<your-production-kv-namespace-id>"

[[env.production.r2_buckets]]
binding = "R2"
bucket_name = "skillscat-storage"

[[env.production.queues.producers]]
binding = "INDEXING_QUEUE"
queue = "skillscat-indexing"

[env.production.vars]
GITHUB_EVENTS_PER_PAGE = "100"
GITHUB_EVENTS_PAGES = "1"
GITHUB_EVENTS_MIN_REST_REMAINING = "1000"
GITHUB_EVENTS_REST_RESERVE = "300"
GITHUB_SEARCH_DISCOVERY_ENABLED = "1"
GITHUB_SEARCH_DISCOVERY_QUERY = "filename:SKILL.md"
GITHUB_SEARCH_DISCOVERY_PAGES = "1"
GITHUB_SEARCH_DISCOVERY_PER_PAGE = "100"
GITHUB_DISCOVERY_CRON_INTERVAL_SECONDS = "300"
GITHUB_DISCOVERY_MIN_REST_REMAINING = "1000"
GITHUB_DISCOVERY_REST_RESERVE = "300"
GITHUB_DISCOVERY_LOCK_TTL_SECONDS = "240"
