# SkillsCat 环境变量配置
# 复制此文件为 .dev.vars 并填入你的配置
# 运行 pnpm init:project 可以自动生成此文件

# ========== 自动生成的 Secrets ==========
# 这些值会由 init 脚本自动生成，无需手动填写
BETTER_AUTH_SECRET=<auto-generated>
WORKER_SECRET=<auto-generated>

# ========== GitHub OAuth ==========
# 创建 OAuth App: https://github.com/settings/developers
# Authorization callback URL: http://localhost:5173/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ========== GitHub Personal Access Token ==========
# 创建 Token: https://github.com/settings/tokens
# 需要的权限: public_repo (用于读取公开仓库信息)
GITHUB_TOKEN=your-github-token

# ========== IndexNow (可选，用于加速 Bing 等搜索引擎发现) ==========
# 获取/生成 key 后，配合 wrangler vars 中的 INDEXNOW_KEY_LOCATION 使用
# 文档: https://www.indexnow.org/documentation
INDEXNOW_KEY=

# ========== OpenRouter API (用于 AI 分类) ==========
# 获取 API Key: https://openrouter.ai/keys
# 注意: 推荐使用免费模型，无需付费
# 查看可用免费模型: https://openrouter.ai/models?q=:free
OPENROUTER_API_KEY=

# 可选: 主模型（默认 openrouter/free，会自动路由到可用免费模型）
AI_MODEL=openrouter/free
# 可选: classification 的付费兜底模型
# CLASSIFICATION_PAID_MODEL=openai/gpt-5.4-nano

# 可选: 免费模型池，逗号分隔 (用于 fallback)
# FREE_MODELS=google/gemma-3-1b-it:free,meta-llama/llama-3.2-1b-instruct:free

# ========== DeepSeek API (兜底策略，可选) ==========
# 获取 API Key: https://platform.deepseek.com/api_keys
# 当 OpenRouter 所有模型都失败时，使用 DeepSeek 作为最后兜底
DEEPSEEK_API_KEY=

# ========== Security Analysis (可选调参) ==========
# 默认 free 模型: openrouter/free; trending / 举报升级后可切到 premium 模型
# SECURITY_FREE_MODEL=openrouter/free
# SECURITY_FREE_MODELS=google/gemma-3-1b-it:free,meta-llama/llama-3.2-1b-instruct:free
# SECURITY_PREMIUM_MODEL=openai/gpt-5.4-nano
# SECURITY_PREMIUM_TOP_N=50
# SECURITY_MAX_AI_FILES=8
# SECURITY_MAX_AI_TEXT_BYTES=48000
# SECURITY_STABILITY_ROUNDS=2
# SECURITY_HEURISTIC_THRESHOLD=4.5

# ========== VirusTotal Public API (可选) ==========
# Public API 需要 API Key，默认按 4 req/min 与 300 req/day 预算设计
VIRUSTOTAL_API_KEY=
# VT_ENABLED=1
# VT_MINUTE_REQUEST_BUDGET=4
# VT_DAILY_REQUEST_BUDGET=300
# VT_UPLOAD_MAX_BYTES=33554432

# ========== Rate Limit Adaptive Penalty (可选) ==========
# 仅在需要调参时设置，不设置则使用系统默认:
# BURST_WINDOW=120s, BURST_THRESHOLD=3, MAX_LEVEL=3, TTL(1/2/3)=300/900/1800s
# RATE_LIMIT_BURST_WINDOW_SECONDS=120
# RATE_LIMIT_BURST_THRESHOLD=3
# RATE_LIMIT_MAX_PENALTY_LEVEL=3
# RATE_LIMIT_PENALTY_TTL_LEVEL_1_SECONDS=300
# RATE_LIMIT_PENALTY_TTL_LEVEL_2_SECONDS=900
# RATE_LIMIT_PENALTY_TTL_LEVEL_3_SECONDS=1800
