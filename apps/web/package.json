{
  "name": "@skillscat/web",
  "version": "0.7.15",
  "type": "module",
  "scripts": {
    "build:sw": "node scripts/build-sw.mjs",
    "dev": "pnpm build:sw && vite dev",
    "build": "pnpm build:sw && vite build",
    "prepare:assetsignore": "node scripts/prepare-assetsignore.mjs",
    "preview": "node scripts/preview.mjs",
    "preview:prod": "node scripts/preview.mjs --prod-data",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "deploy": "pnpm build && pnpm prepare:assetsignore && wrangler deploy -c wrangler.preview.toml --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply skillscat-db --local -c wrangler.preview.toml",
    "db:migrate:prod": "wrangler d1 migrations apply skillscat-db --remote -c wrangler.preview.toml --env production",
    "db:studio": "drizzle-kit studio",
    "tags:normalize": "node scripts/normalize-skill-tags.mjs"
  },
  "dependencies": {
    "@cf-wasm/resvg": "^0.3.3",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/svelte": "^1.1.2",
    "better-auth": "^1.6.5",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "marked": "^17.0.6",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@unocss/preset-icons": "^66.6.8",
    "@unocss/preset-wind": "^66.6.8",
    "@unocss/reset": "^66.6.8",
    "@unocss/svelte-scoped": "^66.6.8",
    "@unocss/transformer-directives": "^66.6.8",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.7",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "typescript": "^5.9.3",
    "unocss": "^66.6.8",
    "vite": "^8.0.8",
    "vitest": "^3.2.4",
    "wrangler": "^4.83.0"
  }
}
